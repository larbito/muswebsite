{
  "name": "tvdyalek-landing",
  "version": "1.0.0",
  "private": true,
  "description": "TVDYALEK — Arabic (RTL) IPTV landing page. Static site; React precompiled from JSX.",
  "scripts": {
    "build": "node build.mjs",
    "serve": "node --eval \"const h=require('http'),f=require('fs'),p=require('path');const t={'.html':'text/html; charset=utf-8','.js':'text/javascript; charset=utf-8','.css':'text/css; charset=utf-8','.svg':'image/svg+xml','.png':'image/png','.jpg':'image/jpeg','.webp':'image/webp','.avif':'image/avif','.json':'application/json'};h.createServer((q,s)=>{let u=decodeURIComponent(q.url.split('?')[0]);if(u==='/')u='/index.html';const fp=p.join(process.cwd(),u);f.readFile(fp,(e,d)=>{if(e){s.writeCode=404;s.statusCode=404;return s.end('404');}s.setHeader('content-type',t[p.extname(fp)]||'application/octet-stream');s.end(d);});}).listen(8000,()=>console.log('http://localhost:8000'));\""
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.27.0"
  }
}
